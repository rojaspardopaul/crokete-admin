# =====================================================
# CROKETE ADMIN (Vite/React) — Environment Variables
# =====================================================
# Copy this file to .env.local and fill in your values.
#
# Stripe y otros secrets de pago se configuran en:
# Admin → Settings → Store Settings (se guardan en la BD).
# =====================================================

# ===== API (REQUERIDO) =====
VITE_APP_API_BASE_URL=http://localhost:5055/v1
VITE_APP_STORE_DOMAIN=http://localhost:3000
VITE_APP_API_SOCKET_URL=http://localhost:5055
VITE_APP_ADMIN_DOMAIN=http://localhost:4100
VITE_APP_SHOP_NAME=Crokete

# ===== CLOUDINARY =====
VITE_APP_CLOUD_NAME=<your_cloudinary_cloud_name>
VITE_APP_CLOUDINARY_API_KEY=<your_cloudinary_api_key>
VITE_APP_CLOUDINARY_UPLOAD_PRESET=<your_upload_preset>
VITE_APP_CLOUDINARY_URL=https://api.cloudinary.com/v1_1/<your_cloud_name>/image/upload

# ===== TRANSLATION API (opcional, tiene limite gratuito) =====
VITE_APP_MYMEMORY_API_KEY=<your_mymemory_api_key>

# ===== ENCRYPTION (REQUERIDO — DEBE SER IGUAL al ENCRYPT_PASSWORD del backend) =====
# Generate with: openssl rand -hex 32
VITE_APP_ENCRYPT_PASSWORD=<your-32-hex-key>
