# Build stage
FROM node:18-slim AS build
WORKDIR /app

# Build arguments for env vars
ARG VITE_APP_API_BASE_URL
ARG VITE_APP_STORE_DOMAIN
ARG VITE_APP_API_SOCKET_URL
ARG VITE_APP_ADMIN_DOMAIN
ARG VITE_APP_CLOUD_NAME
ARG VITE_APP_CLOUDINARY_API_KEY
ARG VITE_APP_CLOUDINARY_API_SECRET
ARG VITE_APP_CLOUDINARY_UPLOAD_PRESET
ARG VITE_APP_CLOUDINARY_URL
ARG VITE_APP_MYMEMORY_API_KEY
ARG VITE_APP_ENCRYPT_PASSWORD

# Set env vars from build args
ENV VITE_APP_API_BASE_URL=$VITE_APP_API_BASE_URL
ENV VITE_APP_STORE_DOMAIN=$VITE_APP_STORE_DOMAIN
ENV VITE_APP_API_SOCKET_URL=$VITE_APP_API_SOCKET_URL
ENV VITE_APP_ADMIN_DOMAIN=$VITE_APP_ADMIN_DOMAIN
ENV VITE_APP_CLOUD_NAME=$VITE_APP_CLOUD_NAME
ENV VITE_APP_CLOUDINARY_API_KEY=$VITE_APP_CLOUDINARY_API_KEY
ENV VITE_APP_CLOUDINARY_API_SECRET=$VITE_APP_CLOUDINARY_API_SECRET
ENV VITE_APP_CLOUDINARY_UPLOAD_PRESET=$VITE_APP_CLOUDINARY_UPLOAD_PRESET
ENV VITE_APP_CLOUDINARY_URL=$VITE_APP_CLOUDINARY_URL
ENV VITE_APP_MYMEMORY_API_KEY=$VITE_APP_MYMEMORY_API_KEY
ENV VITE_APP_ENCRYPT_PASSWORD=$VITE_APP_ENCRYPT_PASSWORD

COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build

# Production stage with nginx
FROM nginx:alpine
COPY --from=build /app/build /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
